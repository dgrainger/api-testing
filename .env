#
# I can use these by uncommenting the settings I want them using:
#   set -a; source .env; set +a
# The set -a means we don't need the 'export' before each setting and we
# set +a to put it back to the way we normally want the shell to behave

#
# Swagger Petstore
#
# API_PROTOCOL=https
# API_HOST=petstore.swagger.io
# API_PORT=443
# API_CONTEXT_ROOT=/v2

#
# httpbin
#
API_PROTOCOL=https
API_HOST=httpbin.org
API_PORT=443
API_CONTEXT_ROOT=
